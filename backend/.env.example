# ---- Sourcewell backend config ----
# Copy to .env and fill in the WorkOS values to enable real login.

FRONTEND_URL=http://localhost:8900

# ---- WorkOS AuthKit ----
# 1) Create an app at https://dashboard.workos.com  (Authentication > AuthKit)
# 2) Copy the API key + Client ID below
# 3) Add this exact redirect URI in WorkOS:  http://localhost:8901/auth/callback
WORKOS_API_KEY=sk_test_xxx
WORKOS_CLIENT_ID=client_xxx
WORKOS_REDIRECT_URI=http://localhost:8901/auth/callback

# Fernet key that seals the session cookie (freshly generated below — keep it secret).
# Regenerate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_COOKIE_PASSWORD=cUYdTpasVSgR9RKRn_d2uAB5o-1ZkQ9CSPgjbPXVX6A=
COOKIE_SECURE=false
